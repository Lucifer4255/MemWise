{
  "name": "memwise",
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first AI memory for Claude Code, Codex, and Cursor — survives compaction",
  "author": "Suhotra Dey <deysuhotra@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/suhotra-dey/memwise.git"
  },
  "homepage": "https://github.com/suhotra-dey/memwise#readme",
  "keywords": ["claude-code", "ai-memory", "mcp", "llm", "coding-agent", "sqlite", "ollama"],
  "engines": { "node": ">=20" },
  "main": "dist/bin/memwise.js",
  "bin": {
    "memwise": "dist/bin/memwise.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/dashboard/index.html dist/dashboard/index.html",
    "prepublishOnly": "npm run build && npm test",
    "test": "npx tsx tests/smoke.ts && npx tsx tests/store/store.test.ts && npx tsx tests/store/migration.test.ts && npx tsx tests/store/turn-graph.test.ts && npx tsx tests/store/layer14.test.ts && npx tsx tests/capture/bracket.test.ts && npx tsx tests/parser/parser.test.ts && MEMWISE_DURABLE_TIERS=on npx tsx tests/retrieval/retrieval.test.ts && npx tsx tests/replay/replay.test.ts && npx tsx tests/replay/transcript-readers.test.ts && npx tsx tests/cli/hook.test.ts && npx tsx tests/enrich/enricher.test.ts && npx tsx tests/enrich/jobs.test.ts && npx tsx tests/adapters/adapters.test.ts && npx tsx tests/dashboard/dashboard.test.ts",
    "test:hook": "npx tsx tests/cli/hook.test.ts",
    "test:enrich": "npx tsx tests/enrich/enricher.test.ts",
    "test:jobs": "npx tsx tests/enrich/jobs.test.ts",
    "test:adapters": "npx tsx tests/adapters/adapters.test.ts",
    "test:retrieval": "MEMWISE_DURABLE_TIERS=on npx tsx tests/retrieval/retrieval.test.ts",
    "test:replay": "npx tsx tests/replay/replay.test.ts",
    "test:readers": "npx tsx tests/replay/transcript-readers.test.ts",
    "test:dashboard": "npx tsx tests/dashboard/dashboard.test.ts",
    "replay": "npx tsx src/replay/replay.ts",
    "memwise-mcp": "npx tsx src/mcp/query-server.ts",
    "test:store": "npx tsx tests/store/store.test.ts",
    "test:graph": "npx tsx tests/store/turn-graph.test.ts",
    "test:smoke": "npx tsx tests/smoke.ts",
    "test:bracket": "npx tsx tests/capture/bracket.test.ts",
    "test:parser": "npx tsx tests/parser/parser.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c": "^0.23.6",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
